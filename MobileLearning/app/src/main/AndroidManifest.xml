<?xml version="1.0" encoding="UTF-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".MainApplication"
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.DarkActionBar"
        android:usesCleartextTraffic="true">
        
        <activity
            android:name=".ui.activity.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <activity
            android:name=".ui.activity.RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.MainActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.CourseListActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.CourseDetailActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.VideoStudyActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.PdfStudyActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.ExamActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.ExamListActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.MyExamActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.ProfileActivity"
            android:exported="false" />
        
    </application>

</manifest>
